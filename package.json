{
  "name": "seon06-blog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev --port 8788 -- vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 execute seon06-blog-db --local --file=migrations/001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute seon06-blog-db --remote --file=migrations/001_initial.sql",
    "deploy": "vite build && wrangler pages deploy dist"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.2",
    "wrangler": "^4.85.0"
  }
}
